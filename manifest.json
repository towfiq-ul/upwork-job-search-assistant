{
  "manifest_version": 3,
  "name": "Upwork Job Search Assistant",
  "version": "1.0.0",
  "description": "Auto-fetches Upwork jobs in the background. Notifies on new jobs.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications",
    "cookies",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.upwork.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png",
      "512": "icons/icon512.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "request_modifier.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png",
    "512": "icons/icon512.png"
  }
}